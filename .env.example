# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=
# Optional: override the "from" address (default: Flat Earth Safety <no-reply@flatearthequipment.com>)
EMAIL_FROM=

# ─── Expo push notifications ──────────────────────────────────────────────────
# Optional: required for FCM v1 / per-project credentials in production.
# Leave empty to use Expo's default (works for development / basic FCM).
EXPO_ACCESS_TOKEN=

# ─── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.flatearthequipment.com

# ─── Feature flags ────────────────────────────────────────────────────────────
# GA (General Availability) gate for the training checkout flow.
FEATURE_GA=0

# "Ask my employer to pay" checkout forwarding feature.
#
# SERVER flag: read by app/api/checkout/route.ts and app/training/checkout/actions.ts
# to append request_id to Stripe session metadata and prefill the billing email.
# Set to '1' to enable. Unset or '0' = feature is inert; behavior is byte-identical
# to the legacy checkout flow.
ENABLE_ASK_EMPLOYER_CHECKOUT=

# CLIENT flag: read by app/safety/CheckoutButton.tsx and
# components/training/PricingStrip.tsx to include request_id and prefill_email
# in the body posted to /api/checkout. Must match ENABLE_ASK_EMPLOYER_CHECKOUT.
NEXT_PUBLIC_ENABLE_ASK_EMPLOYER_CHECKOUT=

# "Ask my employer to pay" webhook fulfillment (Prompt D).
#
# When set to '1', the Stripe webhook (app/api/webhooks/stripe/route.ts) detects
# session.metadata.request_id on checkout.session.completed and:
#   1. Suppresses the four employer-facing side effects
#      (welcome email, enrollment-notification email, buyer enrollments insert,
#       role='trainer' upgrade).
#   2. Runs the ask-employer branch: creates a seat_invite tied to the order,
#      marks purchase_requests.status='paid', emails ExamUnlockedEmail to the
#      employee, sends a push notification, emits an analytics event.
#
# Behavior when unset or '0' is byte-identical to the legacy webhook.
# The new branch only triggers when BOTH flag is '1' AND request_id is present.
#
# Rollout sequence:
#   1. Apply migration 20260421030605_add_order_id_to_seat_invites.sql
#      (adds seat_invites.order_id that the new branch uses for idempotency).
#   2. Deploy code (flag unset = dead branch).
#   3. Verify Stripe auto-receipts are enabled in Stripe Dashboard →
#      Settings → Emails → Successful payments (the employer's purchase
#      acknowledgement is their Stripe receipt; no app-side employer email
#      is sent when this flag is on).
#   4. Flip ENABLE_ASK_EMPLOYER_CHECKOUT=1 to start producing request_id
#      metadata on checkout sessions.
#   5. Flip ENABLE_ASK_EMPLOYER_FULFILLMENT=1 to activate the webhook branch.
ENABLE_ASK_EMPLOYER_FULFILLMENT=
