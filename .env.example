# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=
# Optional: override the "from" address (default: Flat Earth Safety <no-reply@flatearthequipment.com>)
EMAIL_FROM=

# ─── Expo push notifications ──────────────────────────────────────────────────
# Optional: required for FCM v1 / per-project credentials in production.
# Leave empty to use Expo's default (works for development / basic FCM).
EXPO_ACCESS_TOKEN=

# ─── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.flatearthequipment.com

# ─── Feature flags ────────────────────────────────────────────────────────────
# GA (General Availability) gate for the training checkout flow.
FEATURE_GA=0

# "Ask my employer to pay" checkout forwarding feature.
#
# SERVER flag: read by app/api/checkout/route.ts and app/training/checkout/actions.ts
# to append request_id to Stripe session metadata and prefill the billing email.
# Set to '1' to enable. Unset or '0' = feature is inert; behavior is byte-identical
# to the legacy checkout flow.
ENABLE_ASK_EMPLOYER_CHECKOUT=

# CLIENT flag: read by app/safety/CheckoutButton.tsx and
# components/training/PricingStrip.tsx to include request_id and prefill_email
# in the body posted to /api/checkout. Must match ENABLE_ASK_EMPLOYER_CHECKOUT.
NEXT_PUBLIC_ENABLE_ASK_EMPLOYER_CHECKOUT=
